    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@uswds/uswds": "^3.13.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.0",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "angular-eslint": "22.0.0",
    "axe-core": "^4.12.1",
    "eslint": "^10.3.0",
